### Health
GET http://localhost:3000/api/health

###

### Register
POST http://localhost:3000/api/auth/register
Content-Type: application/json

{
  "username": "student",
  "password": "1234"
}

###

### Login
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "username": "student",
  "password": "1234"
}

###

### Refresh
POST http://localhost:3000/api/auth/refresh
Content-Type: application/json
x-refresh-token: REPLACE_WITH_REFRESH

{
  "refreshToken": "REPLACE_WITH_REFRESH"
}

###

### Me
GET http://localhost:3000/api/auth/me
Authorization: Bearer REPLACE_WITH_ACCESS

###

### List properties
GET http://localhost:3000/api/properties

###

### Create property
POST http://localhost:3000/api/properties
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_ACCESS

{
  "title": "Евродвушка с видом на парк",
  "propertyType": "Квартира",
  "address": "Санкт-Петербург, пр. Маршала Блюхера, 21",
  "description": "Современная квартира в новом доме рядом с парком и метро.",
  "price": 10400000,
  "area": 47
}

###

### Property by id
GET http://localhost:3000/api/properties/REPLACE_WITH_ID
Authorization: Bearer REPLACE_WITH_ACCESS

###

### Update property
PUT http://localhost:3000/api/properties/REPLACE_WITH_ID
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_ACCESS

{
  "title": "Евродвушка с отделкой и видом на парк",
  "propertyType": "Квартира",
  "address": "Санкт-Петербург, пр. Маршала Блюхера, 21",
  "description": "Квартира с готовой отделкой, кухней-гостиной и застекленной лоджией.",
  "price": 11200000,
  "area": 47
}

###

### Delete property
DELETE http://localhost:3000/api/properties/REPLACE_WITH_ID
Authorization: Bearer REPLACE_WITH_ACCESS
