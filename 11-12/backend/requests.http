### Health
GET http://localhost:3002/api/health

###

### Register buyer
POST http://localhost:3002/api/auth/register
Content-Type: application/json

{
  "username": "new-buyer",
  "password": "1234",
  "role": "user"
}

###

### Login realtor
POST http://localhost:3002/api/auth/login
Content-Type: application/json

{
  "username": "realtor",
  "password": "realtor123"
}

###

### Refresh
POST http://localhost:3002/api/auth/refresh
Content-Type: application/json
x-refresh-token: REPLACE_WITH_REFRESH

{
  "refreshToken": "REPLACE_WITH_REFRESH"
}

###

### Me
GET http://localhost:3002/api/auth/me
Authorization: Bearer REPLACE_WITH_ACCESS

###

### List properties
GET http://localhost:3002/api/properties
Authorization: Bearer REPLACE_WITH_ACCESS

###

### Create property
POST http://localhost:3002/api/properties
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_ACCESS

{
  "title": "Апартаменты в центре",
  "propertyType": "Апартаменты",
  "address": "Москва, ул. Большая Дмитровка, 18",
  "description": "Объект с дизайнерской отделкой для сдачи в аренду или жизни.",
  "price": 19800000,
  "area": 52
}

###

### Property by id
GET http://localhost:3002/api/properties/REPLACE_WITH_ID
Authorization: Bearer REPLACE_WITH_ACCESS

###

### Update property
PUT http://localhost:3002/api/properties/REPLACE_WITH_ID
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_ACCESS

{
  "title": "Апартаменты в центре с мебелью",
  "propertyType": "Апартаменты",
  "address": "Москва, ул. Большая Дмитровка, 18",
  "description": "Объект с дизайнерской отделкой, мебелью и системой умный дом.",
  "price": 20500000,
  "area": 52
}

###

### Delete property
DELETE http://localhost:3002/api/properties/REPLACE_WITH_ID
Authorization: Bearer REPLACE_WITH_ACCESS

###

### List users (admin)
GET http://localhost:3002/api/users
Authorization: Bearer REPLACE_WITH_ADMIN_ACCESS

###

### User by id (admin)
GET http://localhost:3002/api/users/REPLACE_WITH_USER_ID
Authorization: Bearer REPLACE_WITH_ADMIN_ACCESS

###

### Update user (admin)
PUT http://localhost:3002/api/users/REPLACE_WITH_USER_ID
Content-Type: application/json
Authorization: Bearer REPLACE_WITH_ADMIN_ACCESS

{
  "username": "new-realtor",
  "role": "seller",
  "isBlocked": false
}

###

### Block user (admin)
DELETE http://localhost:3002/api/users/REPLACE_WITH_USER_ID
Authorization: Bearer REPLACE_WITH_ADMIN_ACCESS
